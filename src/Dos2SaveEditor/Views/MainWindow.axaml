<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dos2SaveEditor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="Dos2SaveEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        MinWidth="900" MinHeight="900">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" 
                    Margin="8,8,8,4" Spacing="8">
            <Button Content="Open Save..." Command="{Binding OpenSaveCommand}"
                    IsEnabled="{Binding !IsSaveOpen}"
                    Width="120" Height="32"/>
            <Button Content="Save" Command="{Binding SaveSaveCommand}"
                    IsEnabled="{Binding IsSaveOpen}"
                    Width="80" Height="32"/>
            <Button Content="Close" Command="{Binding CloseSaveCommand}"
                    IsEnabled="{Binding IsSaveOpen}"
                    Width="80" Height="32"/>
            <Separator Width="16" Background="Transparent"/>
            <Button Content="Set Game Data..." Command="{Binding SetGameDataPathCommand}"
                    IsEnabled="{Binding IsSaveOpen}"
                    Width="120" Height="32" FontSize="12"/>
            <Separator Width="16" Background="Transparent"/>
            <TextBlock Text="{Binding StatusText}" 
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- Main content (visible when save is open) -->
        <Grid ColumnDefinitions="260,*" IsVisible="{Binding IsSaveOpen}" Margin="8,0,8,8">
            <!-- Left sidebar: Character list -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,1,0" Padding="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Characters" 
                               FontSize="16" FontWeight="SemiBold"
                               Margin="4,8,4,8"/>
                    <ListBox ItemsSource="{Binding Characters}"
                             SelectedItem="{Binding SelectedCharacter}"
                             DockPanel.Dock="Top">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding ClassType}" FontSize="12"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <!-- Mod count below character list -->
                    <Border DockPanel.Dock="Bottom" Padding="4" Margin="0,8,0,0"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="4">
                        <TextBlock FontSize="12">
                            <Run Text="Mods: "/>
                            <Run Text="{Binding Mods.Count}"/>
                        </TextBlock>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Right content: Tabbed editor -->
            <TabControl Grid.Column="1" Margin="8,0,8,8">
                <TabItem Header="Character">
                    <ContentControl Content="{Binding CharacterEditor}"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    Margin="16,8"/>
                </TabItem>

                <TabItem Header="Inventory">
                    <Grid ColumnDefinitions="*,360" Margin="8">
                        <TreeView Grid.Column="0" ItemsSource="{Binding InventoryItems}"
                                  SelectedItem="{Binding SelectedInventoryItem}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                                        <TextBlock Text="⚔" IsVisible="{Binding IsEquipped}"
                                                   Foreground="LimeGreen" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatsId}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Amount, StringFormat='x{0}'}" 
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding EquipmentSlotName, StringFormat='[{0}]'}" 
                                                   IsVisible="{Binding IsEquipped}"
                                                   Foreground="LimeGreen" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="[BP]" IsVisible="{Binding IsBackpack}"
                                                   Foreground="DodgerBlue" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <!-- Item detail editor on the right — scrollable -->
                        <ScrollViewer Grid.Column="1" Margin="8,0,0,0"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ContentControl Content="{Binding ItemEditor}">
                                <ContentControl.DataTemplates>
                                    <DataTemplate DataType="vm:ItemEditViewModel">
                                        <Border Padding="10"
                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                CornerRadius="6">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Item Details" 
                                                           FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                                <!-- Basic properties -->
                                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Stats ID" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding StatsId}" FontSize="12"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount" FontSize="11" VerticalAlignment="Center"/>
                                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Amount}" 
                                                                   Minimum="1" Maximum="999999" Width="100"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Level" FontSize="11" VerticalAlignment="Center"/>
                                                    <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Level}" 
                                                                   Minimum="0" Maximum="99" Width="100"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Slot" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Slot}" FontSize="12"/>
                                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                                        <CheckBox IsChecked="{Binding IsGenerated}" Content="Generated"
                                                                  ToolTip.Tip="Item was created by the loot generation system. Stats are computed from a template + level + random boosts."/>
                                                        <CheckBox IsChecked="{Binding HasCustomBase}" Content="Custom Base"
                                                                  ToolTip.Tip="Item has custom base stats overridden in the save file, diverging from the template."/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding BackpackLabel, StringFormat='Backpack: {0}'}" 
                                                                   FontSize="11" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Separator -->
                                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,4"/>

                                                <!-- Resolved Stats -->
                                                <TextBlock Text="Stats" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding ResolvedStatsSummary}" 
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SystemControlAccentBrush}"
                                                           IsVisible="{Binding HasResolvedStats}"/>
                                                <TextBlock Text="Use 'Set Game Data...' to load item stats from the game files." 
                                                           FontSize="10" FontStyle="Italic"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           IsVisible="{Binding !HasResolvedStats}"/>

                                                <!-- Override values from save (editable) -->
                                                <TextBlock Text="Overrides (editable)" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gold Value" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GoldValueOverride}" FontSize="10" Width="80"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Weight" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WeightValueOverride}" FontSize="10" Width="80"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Damage Type" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DamageTypeOverride}" FontSize="10" Width="120"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Durability" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HpOverride}" FontSize="10" Width="80"/>
                                                </Grid>

                                                <!-- Extra properties from game data -->
                                                <TextBlock Text="{Binding ExtraStatsText}" 
                                                           FontSize="10" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           IsVisible="{Binding HasResolvedStats}"/>

                                                <!-- Separator -->
                                                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,4"/>

                                                <!-- Runes -->
                                                <TextBlock Text="Runes" FontSize="11" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBox Text="{Binding Rune1}" Width="100" FontSize="11"/>
                                                    <TextBox Text="{Binding Rune2}" Width="100" FontSize="11"/>
                                                    <TextBox Text="{Binding Rune3}" Width="100" FontSize="11"/>
                                                </StackPanel>

                                                <!-- Boosters -->
                                                <TextBlock Text="Boosters" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBox Text="{Binding BoostersText}" FontSize="11"/>

                                                <!-- Delta Mods (editable, one per line) -->
                                                <TextBlock Text="DeltaMods (one per line)" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBox Text="{Binding DeltaModsText}" FontSize="10"
                                                         AcceptsReturn="True" MinHeight="40"
                                                         TextWrapping="Wrap"/>

                                                <!-- Generation overrides -->
                                                <TextBlock Text="Generation" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gen StatsId" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GenerationStatsId}" FontSize="10"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gen Base" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding GenerationBase}" FontSize="10"/>
                                                </Grid>

                                                <!-- Apply -->
                                                <Button Content="Apply Changes"
                                                        Command="{Binding ApplyCommand}"
                                                        HorizontalAlignment="Right" Width="120" Height="30"
                                                        Margin="0,6,0,0"/>

                                                <!-- Diagnostic log (collapsed by default) -->
                                                <Expander Header="Load Log" FontSize="10" 
                                                          IsExpanded="False"
                                                          IsVisible="{Binding HasLoadLog}"
                                                          Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding LoadLogText}" 
                                                               FontSize="9" FontFamily="Menlo,monospace"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                               MaxHeight="200"/>
                                                </Expander>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ContentControl.DataTemplates>
                            </ContentControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Mods">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top" Text="Mod Dependencies" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ListBox ItemsSource="{Binding Mods}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,6">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Uuid}" FontSize="11"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Welcome screen (visible when no save is open) -->
        <Border IsVisible="{Binding !IsSaveOpen}" 
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="40">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="DOS2DE Save Editor" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Open a Divinity: Original Sin 2 Definitive Edition save file to begin editing."
                           FontSize="15" TextWrapping="Wrap" MaxWidth="400"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"/>
                <Button Content="Open Save File..." Command="{Binding OpenSaveCommand}"
                        HorizontalAlignment="Center" Width="200" Height="40"
                        FontSize="15"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
